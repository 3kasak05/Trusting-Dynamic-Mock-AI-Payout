# The port to run the Express backend on
PORT=3001

# The JSON RPC URL for local Hardhat node
RPC_URL=http://127.0.0.1:8545

# Deployed Escrow contract address. 
# In local development, the deploy script will automatically output this to hardhat/deployed_address.txt
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# Anthropic API Key. Set to 'mock' to use high-quality offline simulation mocks.
ANTHROPIC_API_KEY=mock

# GitHub Personal Access Token. Set to 'mock' to use offline simulation mocks.
GITHUB_TOKEN=mock
